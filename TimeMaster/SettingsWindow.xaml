<Window x:Class="TimeMaster.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="640"
        Width="980"
        MinHeight="520"
        MinWidth="880"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="通用设置" Padding="12">
            <StackPanel Orientation="Vertical">
                <CheckBox Content="开机自动启动"
                          IsChecked="{Binding StartWithWindows}" />

                <CheckBox Margin="0,8,0,0"
                          Content="启用鼠标穿透（按住 Ctrl 可临时交互）"
                          IsChecked="{Binding EnableMouseThrough}" />

                <TextBlock Margin="0,6,0,0"
                           Foreground="Gray"
                           Text="提示：开启鼠标穿透时，右键菜单和悬停动画仅在临时交互状态下可用。" />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock VerticalAlignment="Center" Text="主时间窗大小" />
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                        <RadioButton Content="小"
                                     GroupName="ClockSizeGroup"
                                     IsChecked="{Binding IsSizeSmall}" />
                        <RadioButton Content="中"
                                     Margin="12,0,0,0"
                                     GroupName="ClockSizeGroup"
                                     IsChecked="{Binding IsSizeMedium}" />
                        <RadioButton Content="大"
                                     Margin="12,0,0,0"
                                     GroupName="ClockSizeGroup"
                                     IsChecked="{Binding IsSizeLarge}" />
                        <RadioButton Content="超大"
                                     Margin="12,0,0,0"
                                     GroupName="ClockSizeGroup"
                                     IsChecked="{Binding IsSizeExtraLarge}" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <TextBlock VerticalAlignment="Center" Text="主时间窗配色" />
                    <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                        <RadioButton Content="黑底白字"
                                     GroupName="ClockColorGroup"
                                     IsChecked="{Binding IsColorDark}" />
                        <RadioButton Content="白底黑字"
                                     Margin="12,0,0,0"
                                     GroupName="ClockColorGroup"
                                     IsChecked="{Binding IsColorLight}" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="1" Margin="0,12,0,0" Header="提醒配置" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Width="92" Height="30" Content="新增提醒" Click="AddReminder_Click" />
                        <Button Width="92" Height="30" Margin="8,0,0,0" Content="删除提醒" Click="RemoveReminder_Click" />
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               Text="文案1必须包含 {0}，用于显示倒计时秒数" />
                </DockPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Reminders}"
                          SelectedItem="{Binding SelectedReminder}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                        <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="60" />
                        <DataGridTextColumn Header="触发时间" Binding="{Binding Time, UpdateSourceTrigger=PropertyChanged}" Width="100" />
                        <DataGridTextColumn Header="倒计时(秒)" Binding="{Binding CountdownSeconds, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        <DataGridCheckBoxColumn Header="自动关闭" Binding="{Binding AutoCloseTip}" Width="80" />
                        <DataGridTextColumn Header="文案1" Binding="{Binding TipLine1, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                        <DataGridTextColumn Header="文案2" Binding="{Binding TipLine2, UpdateSourceTrigger=PropertyChanged}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Width="96" Height="32" Content="取消" IsCancel="True" />
            <Button Width="96" Height="32" Margin="8,0,0,0" Content="保存" IsDefault="True" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>

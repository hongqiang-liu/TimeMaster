<Window x:Class="TimeMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        Width="156" Height="48"
        ContextMenu="{StaticResource SharedContextMenu}">
    <Window.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="font-digital">pack://application:,,,/TimeMaster;component/Fonts/#Digital-7 Mono</FontFamily>
        </ResourceDictionary>
    </Window.Resources>

    <Border x:Name="ClockBorder"
            CornerRadius="10"
            Background="#88000000"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="ClockScaleTransform" ScaleX="1" ScaleY="1" />
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect x:Name="ClockShadowEffect"
                              Color="#CC000000"
                              Direction="270"
                              ShadowDepth="0"
                              Opacity="0.20"
                              BlurRadius="8" />
        </Border.Effect>

        <TextBlock x:Name="TimeText"
                   Foreground="WhiteSmoke"
                   FontSize="36"
                   FontWeight="Light"
                   FontFamily="{StaticResource font-digital}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Text="00:00:00" />
    </Border>
</Window>

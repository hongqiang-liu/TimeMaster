<Application x:Class="TimeMaster.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TimeMaster"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <local:NotifyIconViewModel x:Key="NotifyCommands" />

        <ContextMenu x:Key="SharedContextMenu"
                     x:Shared="False"
                     DataContext="{StaticResource NotifyCommands}">
            <MenuItem Header="显示时钟窗口" Command="{Binding ShowWindowCommand}" />
            <MenuItem Header="设置" Command="{Binding OpenSettingsCommand}" />
            <MenuItem Header="显示倒计时窗口" Command="{Binding OpenCountdownWindowCommand}" />
            <Separator />
            <MenuItem Header="重新启动" Command="{Binding RestartApplicationCommand}" />
            <Separator />
            <MenuItem Header="退出" Command="{Binding ExitApplicationCommand}" />
        </ContextMenu>

        <tb:TaskbarIcon x:Key="NotifyIcon"
                        IconSource="pack://application:,,,/favicon.ico"
                        ToolTipText="桌面时钟"
                        DataContext="{StaticResource NotifyCommands}"
                        LeftClickCommand="{Binding ShowWindowCommand}"
                        ContextMenu="{StaticResource SharedContextMenu}" />
    </Application.Resources>
</Application>

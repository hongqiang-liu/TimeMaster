<Window x:Class="TimeMaster.CountdownWindow"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CountdownWindow" 
        WindowStyle="None"
        WindowState="Maximized"
        AllowsTransparency="True"
        Topmost="True"
        Background="Transparent"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*" />
            <RowDefinition Height="2*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0"
            Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <TextBlock x:Name="tipLine1L" 
                       Text="还有" 
                       FontSize="64" 
                       Foreground="White"/>
            <TextBlock x:Name="txtCountdown" 
                       Margin="10,0,10,0"
                       Text="60" 
                       FontSize="64" 
                       Foreground="White"
                       FontWeight="Bold"/>
            <TextBlock x:Name="tipLine1R" 
                       Text="秒就到点了" 
                       FontSize="64" 
                       Foreground="White"/>
        </StackPanel>
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top">
            <TextBlock x:Name="tipLine2"
                       Text="不要熬夜，立即睡觉" 
                       FontSize="96" 
                       Foreground="#dc3545" />
        </StackPanel>
    </Grid>
</Window>
